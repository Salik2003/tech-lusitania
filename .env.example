# Supabase — get from: supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# WhatsApp — international format without + or spaces (e.g. 44 followed by number)
NEXT_PUBLIC_WHATSAPP_NUMBER=your_whatsapp_number

# Site info
NEXT_PUBLIC_SITE_NAME=Tech Lusitania
# For local dev use http://localhost:3000, for production use your Vercel URL
NEXT_PUBLIC_SITE_URL=https://tech-lusitania.vercel.app
